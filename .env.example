# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Frontend (exposed to browser via Vite) ──────────────────────
VITE_KIMI_AUTH_URL=       # Kimi OAuth server URL (e.g. https://auth.kimi.com)
VITE_APP_ID=              # OAuth application ID

# ── Backend (Auth) ─────────────────────────────────────────────
KIMI_AUTH_URL=http://localhost:1
KIMI_OPEN_URL=http://localhost:1

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # Union ID of the app creator; this user gets role "admin" on first login

# ── Backend (GPS51) ───────────────────────────────────────────
GPS51_USERNAME=           # GPS51 API account username (server-side only)
GPS51_PASSWORD=           # GPS51 API account password (server-side only)
GPS51_DEVICE_ID=          # Optional: tracker deviceid/IMEI; defaults to hardcoded value if empty

# Legacy fallback (temporary): server still reads these if GPS51_* are unset
VITE_GPS51_USERNAME=      # Deprecated
VITE_GPS51_PASSWORD=      # Deprecated